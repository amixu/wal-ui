{
  "name": "wal-ui-test",
  "version": "0.1.2",
  "description": "Vue 3 UI components built on Naive UI (Wal UI)",
  "type": "module",
  "license": "MIT",
  "keywords": ["vue", "vue3", "naive-ui", "components", "wal-ui"],
  "sideEffects": ["**/*.css", "**/*.vue"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./components.css": "./dist/components.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@iconify/vue": "^4.0.0 || ^5.0.0",
    "@iconify-icons/ri": "^1.2.10",
    "axios": "^1.6.0",
    "chinese-workday": "^2.0.0",
    "naive-ui": "^2.38.0",
    "solarlunar": "^3.1.0",
    "vue": "^3.3.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@iconify/vue": "^5.0.0",
    "axios": "^1.15.0",
    "chinese-workday": "^2.0.0",
    "naive-ui": "^2.44.1",
    "solarlunar": "^3.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  }
}
